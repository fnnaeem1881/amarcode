{
  "name": "@amarcode/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx ./src/**/*.test.ts"
  },
  "dependencies": {
    "@amarcode/shared": "*",
    "chokidar": "^4.0.1",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "nanoid": "^5.0.9",
    "playwright": "^1.61.1",
    "simple-git": "^3.27.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
